{
  "manifest_version": 3,
  "name": "INFINITY AI BEAST AGENT",
  "version": "2.5.2",
  "description": "INFINITY AI — content controller for PocketOption.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "INFINITY AI BEAST AGENT",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://pocketoption.com/*",
    "https://*.pocketoption.com/*",
    "https://api.telegram.org/*",
    "https://raw.githubusercontent.com/*",
    "https://*.workers.dev/*",
    "https://corsproxy.io/*",
    "https://gist.githubusercontent.com/*",
    "https://githubusercontent.com/*",
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pocketoption.com/*",
        "https://*.pocketoption.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "logo.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "https://pocketoption.com/*",
        "https://*.pocketoption.com/*"
      ]
    }
  ]
}
